# GitHub Authentication (Required for non-interactive / CI environments)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_personal_access_token_here

# MobAI Protocol Configuration (Optional)
# Used for remote device connection and interaction
MOBAI_HOST=remote-mac.local
MOBAI_PORT=12345
MOBAI_API_KEY=your_mobai_api_key_here

# Apple Developer / Code Signing Configurations (Optional)
# Can be used to inject signing configurations dynamically
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_CERTIFICATE_PATH=/path/to/certificate.p12
APPLE_CERTIFICATE_PASSWORD=your_certificate_password
APPLE_PROVISIONING_PROFILE=/path/to/profile.mobileprovision

# Builder Configuration Paths (Optional)
# Override the default builder.json path if needed
BUILDER_CONFIG_PATH=./builder.json
